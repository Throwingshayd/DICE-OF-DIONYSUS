{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Game (Vite)",
      "type": "npm",
      "script": "dev",
      "problemMatcher": {
        "owner": "vite",
        "pattern": { "regexp": ".", "file": 1, "location": 2, "message": 3 },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "(Local:|localhost:3000)"
        }
      },
      "isBackground": true,
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated",
        "focus": false
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
