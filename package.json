{
  "name": "dice-of-dionysus",
  "version": "1.4.0",
  "description": "An elegant dice strategy game of pips, favour, and devotion",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "lint": "eslint js/**/*.js",
    "lint:fix": "eslint js/**/*.js --fix",
    "type-check": "tsc --noEmit",
    "start": "electron .",
    "build:electron": "electron-builder",
    "dist": "electron-builder --publish=never"
  },
  "keywords": [
    "dice",
    "game",
    "strategy",
    "mythology",
    "greek",
    "yahtzee",
    "balatro"
  ],
  "author": "Dice of Dionysus Team",
  "license": "UNLICENSED",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitejs/plugin-legacy": "^5.0.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "eslint": "^8.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0",
    "@vitest/ui": "^1.0.0"
  },
  "dependencies": {
    "workbox-window": "^7.0.0"
  },
  "build": {
    "appId": "com.diceofdionysus.game",
    "productName": "Dice of Dionysus",
    "directories": {
      "output": "dist"
    },
    "files": [
      "dist/**/*",
      "ART/**/*",
      "!node_modules/**/*"
    ],
    "win": {
      "target": "portable",
      "icon": "ART/Title art.png"
    },
    "portable": {
      "artifactName": "DiceOfDionysus-v1.4-Portable.exe"
    }
  }
}