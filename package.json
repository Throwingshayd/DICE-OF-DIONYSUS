{
  "name": "dice-of-dionysus",
  "version": "1.4.0",
  "description": "An elegant dice strategy game of pips, favour, and devotion",
  "type": "module",
  "scripts": {
    "predev": "node scripts/ensure-art-junction.cjs",
    "postinstall": "node scripts/ensure-art-junction.cjs",
    "dev": "vite",
    "dev:all": "concurrently \"npm run dev\" \"npm run image-gen\"",
    "extract-boons": "node tools/extract-boons.cjs",
    "import-boon": "node tools/import-boon-to-game.cjs",
    "image-gen": "node tools/image-gen-server.cjs",
    "build": "vite build",
    "clean": "node tools/clean-builds.cjs",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "playtest:boons": "playwright test tests/e2e/boon-playtest.spec.js",
    "lint": "eslint game/js/**/*.js",
    "lint:fix": "eslint game/js/**/*.js --fix",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "dice",
    "game",
    "strategy",
    "mythology",
    "greek",
    "yahtzee",
    "balatro"
  ],
  "author": "Dice of Dionysus Team",
  "license": "UNLICENSED",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^20.0.0",
    "@vitejs/plugin-legacy": "^5.0.0",
    "@vitest/ui": "^1.0.0",
    "baseline-browser-mapping": "^2.10.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "dependencies": {
    "workbox-window": "^7.0.0"
  }
}
